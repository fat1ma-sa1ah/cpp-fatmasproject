#include <iostream>
using namespace std;

int main() {
    float m1, m2, m3, average;

    cout << "Enter marks for 3 subjects:\n";
    cin >> m1 >> m2 >> m3;

    average = (m1 + m2 + m3) / 3;

    cout << "Average = " << average << endl;

    if (average >= 90)
        cout << "Grade: A" << endl;
    else if (average >= 75)
        cout << "Grade: B" << endl;
    else if (average >= 60)
        cout << "Grade: C" << endl;
    else
        cout << "Grade: Fail" << endl;

    return 0;
}
